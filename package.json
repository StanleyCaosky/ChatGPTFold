{
  "name": "chatgpt-long-conversation-stabilizer",
  "version": "1.2.2",
  "private": true,
  "description": "Chrome/Edge extension to optimize ChatGPT long conversation performance and auto-collapse long messages",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build && node ./scripts/generate-manifest.mjs",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/webextension-polyfill": "^0.12.1",
    "jsdom": "^29.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "webextension-polyfill": "^0.12.0"
  }
}
